# Строка подключения к PostgreSQL (asyncpg-драйвер)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/docs_checker

# Параметры контейнера PostgreSQL (docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=docs_checker

# Каталог для хранения загруженных файлов
UPLOAD_DIR=uploads

# Максимальный размер одного файла, МБ
MAX_FILE_SIZE_MB=20

# Разрешенные расширения файлов (через запятую)
ALLOWED_EXTENSIONS=pdf,docx,jpg,jpeg,png
